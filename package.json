{
  "name": "@tb-dev/auto-import-config",
  "version": "9.2.18",
  "description": "Config for unplugin-auto-import",
  "license": "MIT",
  "type": "module",
  "private": false,
  "packageManager": "pnpm@10.32.1",
  "funding": "https://github.com/sponsors/ferreira-tb",
  "homepage": "https://github.com/ferreira-tb/auto-import-config",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ferreira-tb/auto-import-config.git"
  },
  "bugs": {
    "url": "https://github.com/ferreira-tb/auto-import-config/issues"
  },
  "scripts": {
    "build": "vite build",
    "format": "dprint fmt",
    "lint": "eslint . --config eslint.config.js",
    "lint-fix": "eslint . --config eslint.config.js --fix",
    "release": "pnpm run build && pnpm publish",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "unplugin-auto-import": "^21.0.0",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@tb-dev/eslint-config": "^9.0.3",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.30"
  },
  "peerDependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tb-dev/utils": "^7.3.6",
    "@vueuse/core": "^14.2.1",
    "@vueuse/math": "^14.2.1",
    "@vueuse/router": "^14.2.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "files": [
    "dist/**/*"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  }
}
